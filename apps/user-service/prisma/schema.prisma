generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  passenger
  driver
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  fullName  String
  password  String
  role      UserRole @default(passenger)
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
